root = true

# ── All files ────────────────────────────────────────────────────────────────
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
trim_trailing_whitespace = true
insert_final_newline = true

# ── JSON / YAML / TOML  (keep 2-space for config files) ─────────────────────
[*.{json,yaml,yml,toml}]
indent_size = 4

# ── Markdown  (allow trailing spaces for hard line-breaks) ───────────────────
[*.md]
trim_trailing_whitespace = false
indent_size = 4

# ── Makefiles require tabs ───────────────────────────────────────────────────
[Makefile]
indent_style = tab
