# ════════════════════════════════════════════════════════════════════════════
#  SplitEase — backend environment variables
#  Copy this file to .env and fill in your values.
#  All validation is handled by src/lib/env.ts (Zod) at startup.
# ════════════════════════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────────────────────
# PostgreSQL connection string.  Free options: https://neon.tech  https://supabase.com
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# JWT signing secret — generate with:  openssl rand -base64 32
JWT_SECRET="change-this-to-a-long-random-secret"

# Origin the browser uses to reach the frontend (used for CORS)
FRONTEND_URL="http://localhost:5173"

PORT=3001
NODE_ENV=development

# Absolute path for uploaded avatar files.  Defaults to ./uploads
# UPLOADS_DIR=/var/data/splitease/uploads

# ── OAuth — Social Login ──────────────────────────────────────────────────────
# Base URL prepended to OAuth callback paths.  In dev this routes through the
# Vite proxy so the JWT cookie lands on the correct origin.
OAUTH_CALLBACK_BASE=http://localhost:5173

# Google — https://console.cloud.google.com
#   Authorized redirect URI: ${OAUTH_CALLBACK_BASE}/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub — https://github.com/settings/developers
#   Authorization callback URL: ${OAUTH_CALLBACK_BASE}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_ENABLED=false

# Which provider to use: smtp | sendgrid | ses   (default: smtp)
EMAIL_PROVIDER=smtp

# Sender address shown in all outbound emails
EMAIL_FROM="SplitEase <noreply@splitease.app>"

# ── Email › SMTP (nodemailer)  ────────────────────────────────────────────────
# Used when EMAIL_PROVIDER=smtp
# Works with Gmail, Mailgun, Mailpit (local dev), and any SMTP relay.
#
# Gmail quick-start:
#   1. Enable 2-step verification on your Google account
#   2. Create an App Password at https://myaccount.google.com/apppasswords
#   3. Use that 16-char password as SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your-16-char-app-password

# ── Email › SendGrid ─────────────────────────────────────────────────────────
# Used when EMAIL_PROVIDER=sendgrid
# Create an API key at https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Email › Amazon SES v2 ─────────────────────────────────────────────────────
# Used when EMAIL_PROVIDER=ses
# Requires the sender address to be verified in the SES console.
# If running on AWS (EC2/Lambda/ECS) with an IAM role that has SES permissions,
# leave AWS_ACCESS_KEY_ID and AWS_SECRET_ACCESS_KEY empty — the SDK uses the role.
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ── SMS ───────────────────────────────────────────────────────────────────────
SMS_ENABLED=false

# Which provider to use: twilio | msg91   (default: twilio)
SMS_PROVIDER=twilio

# ── SMS › Twilio ─────────────────────────────────────────────────────────────
# Used when SMS_PROVIDER=twilio
# Dashboard: https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM=+15551234567

# ── SMS › MSG91 ───────────────────────────────────────────────────────────────
# Used when SMS_PROVIDER=msg91
# Dashboard: https://control.msg91.com
#
# MSG91_SENDER_ID must be exactly 6 characters and DLT-registered in India.
# MSG91_DLT_TE_ID is the TRAI template entity ID (required for Indian telecom
# operators; obtain it from the DLT platform where you register templates).
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_SENDER_ID=SPLTEZ
MSG91_DLT_TE_ID=
